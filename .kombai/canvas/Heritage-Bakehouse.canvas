  "nodes": {
    "node_paste_7e380d1d31c6": {
      "type": "variant",
      "id": "node_paste_7e380d1d31c6",
      "label": "Heritage Bakehouse",
      "html": "<style>\n    :root {\n      --cream: #F3EADA;\n      --paper: #FBF4E6;\n      --ink: #3A241A;\n      --ink-soft: #7A5A45;\n      --jam: #C81E37;\n      --ember: #E2611B;\n      --night: #231410;\n      /* live inversion props (Season) */\n      --inv-bg: #F3EADA;\n      --inv-text: #3A241A;\n      --inv-accent: #C81E37;\n    }\n\n    * {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    html {\n      scroll-behavior: smooth;\n    }\n\n    body {\n      background: var(--cream);\n      color: var(--ink);\n      font-family: 'Spectral', Georgia, serif;\n      font-weight: 400;\n      line-height: 1.65;\n      -webkit-font-smoothing: antialiased;\n      background-image:\n        radial-gradient(rgba(58, 36, 26, 0.05) 1px, transparent 1px),\n        radial-gradient(rgba(58, 36, 26, 0.035) 1px, transparent 1px);\n      background-size: 4px 4px, 9px 9px;\n      background-position: 0 0, 2px 3px;\n      overflow-x: hidden;\n    }\n\n    .disp {\n      font-family: 'Marcellus', serif;\n      font-weight: 400;\n    }\n\n    .script {\n      font-family: 'Caveat', cursive;\n    }\n\n    em {\n      font-style: italic;\n      color: var(--jam);\n    }\n\n    .label {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.22em;\n      font-size: 12px;\n      color: var(--ink-soft);\n    }\n\n    .pgnum {\n      font-family: 'Spectral', serif;\n      font-style: italic;\n      color: var(--jam);\n    }\n\n    a {\n      color: inherit;\n      text-decoration: none;\n    }\n\n    img {\n      display: block;\n      max-width: 100%;\n    }\n\n    .wrap {\n      max-width: 1180px;\n      margin: 0 auto;\n      padding: 0 40px;\n    }\n\n    /* hand-drawn rule */\n    .rule {\n      height: 8px;\n      background-repeat: no-repeat;\n      background-size: 100% 100%;\n      background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 8' preserveAspectRatio='none'><path d='M2 4 C 60 1, 120 7, 180 3 S 320 6, 398 4' stroke='%23C81E37' stroke-width='1.6' fill='none' stroke-linecap='round'/></svg>\");\n    }\n\n    /* ============ HERO ============ */\n    .hero {\n      position: relative;\n      min-height: 100vh;\n      overflow: hidden;\n      display: flex;\n      align-items: center;\n    }\n\n    .hero-bg {\n      position: absolute;\n      inset: 0;\n      z-index: 0;\n      background: linear-gradient(160deg, var(--cream) 0%, #efd8b6 45%, var(--ember) 120%);\n    }\n\n    .hero-vid {\n      position: absolute;\n      top: -10%;\n      left: -5%;\n      width: 120%;\n      height: 120%;\n      object-fit: cover;\n      object-position: 30% 65%;\n      z-index: 1;\n      will-change: transform, opacity;\n    }\n\n    .hero-overlay {\n      position: absolute;\n      inset: 0;\n      z-index: 2;\n      pointer-events: none;\n      background:\n        radial-gradient(ellipse at 100% 0%,\n          rgba(243, 234, 218, 0.97) 0%,\n          rgba(243, 234, 218, 0.75) 16%,\n          transparent 38%),\n        linear-gradient(to bottom,\n          rgba(35, 20, 16, 0.28) 0%,\n          rgba(35, 20, 16, 0.00) 32%,\n          rgba(35, 20, 16, 0.00) 60%,\n          rgba(35, 20, 16, 0.35) 100%);\n    }\n\n    .brand {\n      position: absolute;\n      top: 26px;\n      left: 40px;\n      z-index: 6;\n    }\n\n    .brand .b1 {\n      font-size: 42px;\n      line-height: 0.82;\n      color: var(--jam);\n    }\n\n    .brand .b2 {\n      font-size: 30px;\n      line-height: 0.9;\n      color: var(--ink);\n      padding-left: 14px;\n      margin-top: -2px;\n    }\n\n    .brand .rule {\n      width: 130px;\n      margin-top: 6px;\n    }\n\n    .nav {\n      position: absolute;\n      top: 32px;\n      right: 40px;\n      z-index: 6;\n      display: flex;\n      align-items: center;\n      gap: 30px;\n    }\n\n    .nav a {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.18em;\n      font-size: 12.5px;\n      color: var(--ink);\n      transition: color .25s;\n    }\n\n    .nav a:hover {\n      color: var(--jam);\n    }\n\n    .nav .pgnum {\n      font-size: 15px;\n    }\n\n    .hero-frame {\n      position: relative;\n      z-index: 5;\n      margin-left: 7vw;\n      width: min(620px, 82vw);\n      background: rgba(251, 244, 230, 0.12);\n      backdrop-filter: blur(1.5px);\n      border: 1px solid rgba(226, 97, 27, 0.55);\n      padding: 54px 48px 46px;\n      box-shadow: 0 30px 80px -40px rgba(35, 20, 16, 0.6);\n      clip-path: inset(0 0 0 0);\n    }\n\n    .hero-frame::after {\n      content: \"\";\n      position: absolute;\n      left: 0;\n      right: 0;\n      bottom: 0;\n      height: 2px;\n      background: var(--frame-glow, var(--ember));\n      transition: background .2s;\n    }\n\n    .hero-frame.reveal {\n      animation: frameIn 1.1s cubic-bezier(.2, .8, .2, 1) both;\n    }\n\n    @keyframes frameIn {\n      from {\n        clip-path: inset(0 0 100% 0);\n        opacity: 0;\n      }\n\n      to {\n        clip-path: inset(0 0 0 0);\n        opacity: 1;\n      }\n    }\n\n    .hero-eyebrow {\n      font-size: 14px;\n      margin-bottom: 14px;\n    }\n\n    .hero-frame h1 {\n      font-family: 'Marcellus', serif;\n      font-size: clamp(40px, 6.2vw, 80px);\n      line-height: 0.96;\n      color: var(--ink);\n    }\n\n    .hero-frame h1 .w {\n      display: inline-block;\n      transform: translateY(42px);\n      opacity: 0;\n      transition: transform .8s cubic-bezier(.2, .8, .2, 1), opacity .8s;\n      transition-delay: calc(var(--i)*70ms);\n    }\n\n    .loaded .hero-frame h1 .w {\n      transform: translateY(0);\n      opacity: 1;\n    }\n\n    .hero-frame .rule {\n      width: 240px;\n      margin: 22px 0;\n    }\n\n    .hero-body {\n      font-size: 17px;\n      color: var(--ink);\n      max-width: 30em;\n    }\n\n    .hero-ctas {\n      margin-top: 30px;\n      display: flex;\n      align-items: center;\n      gap: 22px;\n      flex-wrap: wrap;\n    }\n\n    .btn-jam {\n      display: inline-block;\n      background: var(--jam);\n      color: var(--cream);\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.2em;\n      font-size: 12.5px;\n      font-weight: 500;\n      padding: 14px 26px;\n      border-radius: 999px;\n      transition: background .25s, transform .25s;\n    }\n\n    .btn-jam:hover {\n      background: var(--ember);\n      transform: translateY(-2px);\n    }\n\n    .btn-jam:focus-visible {\n      outline: 3px solid var(--ember);\n      outline-offset: 3px;\n    }\n\n    .begin {\n      font-family: 'Caveat', cursive;\n      font-size: 26px;\n      color: var(--jam);\n    }\n\n    .scrollcue {\n      position: absolute;\n      bottom: 24px;\n      left: 50%;\n      transform: translateX(-50%);\n      z-index: 6;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      color: var(--cream);\n      text-shadow: 0 1px 4px rgba(35, 20, 16, 0.5);\n      animation: floaty 3.4s ease-in-out infinite;\n    }\n\n    .scrollcue .script {\n      font-size: 22px;\n    }\n\n    @keyframes floaty {\n\n      0%,\n      100% {\n        transform: translateX(-50%) translateY(-3px);\n      }\n\n      50% {\n        transform: translateX(-50%) translateY(5px);\n      }\n    }\n\n    /* gingham divider */\n    .gingham {\n      height: 14px;\n      background-image:\n        linear-gradient(90deg, rgba(200, 30, 55, 0.16) 50%, transparent 50%),\n        linear-gradient(rgba(200, 30, 55, 0.16) 50%, transparent 50%);\n      background-size: 14px 14px, 14px 14px;\n    }\n\n    /* chapter header */\n    .chap-eyebrow {\n      font-family: 'Spectral', serif;\n      font-style: italic;\n      color: var(--jam);\n      font-size: 15px;\n    }\n\n    .chap-title {\n      font-family: 'Marcellus', serif;\n      font-size: clamp(34px, 4.4vw, 56px);\n      color: var(--ink);\n      line-height: 1.02;\n      margin-top: 4px;\n    }\n\n    /* generic line-reveal heading */\n    .linereveal {\n      display: inline-block;\n      clip-path: inset(0 100% 0 0);\n      transition: clip-path 1s cubic-bezier(.2, .8, .2, 1);\n    }\n\n    .linereveal.in {\n      clip-path: inset(0 0 0 0);\n    }\n\n    /* ============ SHELF (#24) ============ */\n    .shelf {\n      position: relative;\n      padding: 110px 0 96px;\n    }\n\n    .shelf-head {\n      display: flex;\n      align-items: flex-end;\n      justify-content: space-between;\n      gap: 24px;\n      will-change: transform;\n    }\n\n    .shelf-head .freshly {\n      font-family: 'Caveat', cursive;\n      font-size: 30px;\n      line-height: 1;\n      text-align: right;\n    }\n\n    .shelf-head .freshly .a {\n      color: var(--jam);\n    }\n\n    .shelf-head .freshly .b {\n      color: var(--ink-soft);\n      display: block;\n      margin-top: -4px;\n    }\n\n    .tabs {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 6px;\n      margin-top: 34px;\n      border-bottom: 1px solid rgba(122, 90, 69, 0.3);\n      padding-bottom: 14px;\n    }\n\n    .tab {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.18em;\n      font-size: 12px;\n      color: var(--ink-soft);\n      background: none;\n      border: none;\n      cursor: pointer;\n      padding: 8px 14px;\n      position: relative;\n      transition: color .25s;\n    }\n\n    .tab::after {\n      content: \"\";\n      position: absolute;\n      left: 14px;\n      right: 14px;\n      bottom: -15px;\n      height: 2px;\n      background: var(--jam);\n      transform: scaleX(0);\n      transform-origin: left;\n      transition: transform .3s;\n    }\n\n    .tab:hover {\n      color: var(--ember);\n    }\n\n    .tab.active {\n      color: var(--ink);\n    }\n\n    .tab.active::after {\n      transform: scaleX(1);\n    }\n\n    .tab:focus-visible {\n      outline: 2px solid var(--ember);\n      outline-offset: 2px;\n    }\n\n    .reclist {\n      margin-top: 30px;\n      border-top: 1px solid rgba(122, 90, 69, 0.18);\n    }\n\n    .recitem {\n      display: flex;\n      align-items: baseline;\n      justify-content: space-between;\n      gap: 24px;\n      padding: 22px 4px;\n      border-bottom: 1px solid rgba(122, 90, 69, 0.18);\n      cursor: pointer;\n      transform: translateY(26px);\n      opacity: 0;\n      transition: transform .7s cubic-bezier(.2, .8, .2, 1), opacity .7s, color .25s;\n    }\n\n    .recitem.in {\n      transform: translateY(0);\n      opacity: 1;\n    }\n\n    .recitem .rtitle {\n      font-family: 'Marcellus', serif;\n      font-size: clamp(26px, 3.6vw, 50px);\n      line-height: 1;\n      color: var(--ink);\n      transition: color .25s, transform .25s;\n    }\n\n    .recitem .rmeta {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.16em;\n      font-size: 12px;\n      color: var(--ink-soft);\n      white-space: nowrap;\n    }\n\n    .recitem:hover .rtitle {\n      color: var(--ember);\n      transform: translateX(10px);\n    }\n\n    .recnum {\n      font-family: 'Spectral', serif;\n      font-style: italic;\n      color: var(--jam);\n      font-size: 14px;\n      margin-right: 14px;\n    }\n\n    .preview {\n      position: fixed;\n      top: 0;\n      left: 0;\n      width: 280px;\n      height: 360px;\n      pointer-events: none;\n      z-index: 40;\n      transform: translate(-50%, -50%) scale(0.92);\n      opacity: 0;\n      transition: opacity .3s, transform .3s;\n      border: 1px solid var(--jam);\n      background: var(--ember);\n      box-shadow: 0 24px 50px -24px rgba(35, 20, 16, 0.7);\n      will-change: transform, left, top;\n      overflow: hidden;\n    }\n\n    .preview.show {\n      opacity: 1;\n      transform: translate(-50%, -50%) scale(1);\n    }\n\n    .preview img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    .preview .ptext {\n      position: absolute;\n      inset: 0;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      color: var(--cream);\n      text-align: center;\n      padding: 18px;\n    }\n\n    .preview .ptext .pt-title {\n      font-family: 'Marcellus', serif;\n      font-size: 22px;\n      line-height: 1.05;\n    }\n\n    .preview .ptext .pt-meta {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.18em;\n      font-size: 11px;\n      margin-top: 10px;\n      opacity: 0.9;\n    }\n\n    /* ============ SEASON (#26) ============ */\n    .season-intro {\n      padding: 80px 0 0;\n    }\n\n    .season-intro-grid {\n      display: flex;\n      flex-wrap: wrap;\n      align-items: flex-end;\n      justify-content: space-between;\n      gap: 30px;\n    }\n\n    .season-intro p.lead {\n      max-width: 30em;\n      font-size: 16px;\n      color: var(--ink-soft);\n    }\n\n    .season-outer {\n      position: relative;\n      height: 400vh;\n    }\n\n    .season-sticky {\n      position: sticky;\n      top: 0;\n      height: 100vh;\n      overflow: hidden;\n      background: var(--inv-bg);\n      color: var(--inv-text);\n      transition: background .15s linear, color .15s linear;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .season-stage {\n      position: relative;\n      width: 100%;\n      height: 100%;\n    }\n\n    .season-pane {\n      position: absolute;\n      inset: 0;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      opacity: 0;\n      filter: blur(14px);\n      transition: opacity .4s, filter .4s;\n    }\n\n    .season-pane.active {\n      opacity: 1;\n      filter: blur(0);\n    }\n\n    .season-pane .snum {\n      font-family: 'Spectral', serif;\n      font-style: italic;\n      font-size: 18px;\n      color: var(--inv-accent);\n    }\n\n    .season-pane h3 {\n      font-family: 'Marcellus', serif;\n      font-style: italic;\n      font-size: clamp(56px, 10vw, 128px);\n      line-height: 0.95;\n    }\n\n    .season-pane .sing {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.3em;\n      font-size: 13px;\n      margin-top: 18px;\n      opacity: 0.85;\n    }\n\n    .season-img {\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      opacity: 0.5;\n      pointer-events: none;\n      z-index: 0;\n    }\n\n    .season-pane .snum,\n    .season-pane h3,\n    .season-pane .sing {\n      position: relative;\n      z-index: 1;\n      text-shadow:\n        0 1px 14px var(--inv-bg),\n        0 0 34px var(--inv-bg);\n    }\n\n    .sun-arc {\n      position: absolute;\n      left: 0;\n      top: 0;\n      width: 100%;\n      height: 100%;\n      pointer-events: none;\n    }\n\n    .sun-dot {\n      fill: var(--inv-accent);\n    }\n\n    .season-prog {\n      position: absolute;\n      bottom: 40px;\n      left: 50%;\n      transform: translateX(-50%);\n      display: flex;\n      gap: 10px;\n      z-index: 3;\n    }\n\n    .season-prog span {\n      width: 34px;\n      height: 3px;\n      background: currentColor;\n      opacity: 0.25;\n      transition: opacity .3s;\n    }\n\n    .season-prog span.on {\n      opacity: 1;\n    }\n\n    /* ============ STORIES (#5) ============ */\n    .stories-outer {\n      position: relative;\n      height: 400vh;\n    }\n\n    .stories-sticky {\n      position: sticky;\n      top: 0;\n      height: 100vh;\n      overflow: hidden;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .stories-head {\n      padding: 40px 40px 0;\n      display: flex;\n      align-items: flex-end;\n      justify-content: space-between;\n      gap: 20px;\n      flex: 0 0 auto;\n    }\n\n    .stories-head .sideways {\n      font-family: 'Caveat', cursive;\n      font-size: 30px;\n      color: var(--jam);\n    }\n\n    .stories-track {\n      flex: 1 1 auto;\n      position: relative;\n      overflow: hidden;\n    }\n\n    .stories-strip {\n      display: flex;\n      height: 100%;\n      width: 400vw;\n      will-change: transform;\n    }\n\n    .splate {\n      width: 100vw;\n      height: 100%;\n      flex: 0 0 100vw;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 40px 6vw;\n    }\n\n    .splate-card {\n      display: grid;\n      grid-template-columns: 0.85fr 1fr;\n      gap: 46px;\n      max-width: 1040px;\n      width: 100%;\n      align-items: center;\n      background: var(--paper);\n      padding: 46px;\n      position: relative;\n      box-shadow: 0 30px 60px -34px rgba(35, 20, 16, 0.5);\n      transform: scale(0.97);\n      transition: transform .4s;\n    }\n\n    .splate.center .splate-card {\n      transform: scale(1);\n    }\n\n    .splate-card::before {\n      content: \"\";\n      position: absolute;\n      top: -12px;\n      left: 46px;\n      width: 120px;\n      height: 26px;\n      background: rgba(226, 97, 27, 0.7);\n      transform: rotate(-3deg);\n      border-top: 1px dashed rgba(58, 36, 26, 0.4);\n      border-bottom: 1px dashed rgba(58, 36, 26, 0.4);\n    }\n\n    .splate-portrait {\n      aspect-ratio: 4/5;\n      background: var(--jam);\n      overflow: hidden;\n      border: 1px solid rgba(58, 36, 26, 0.35);\n    }\n\n    .splate-portrait img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    .splate-body .ess-num {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.2em;\n      font-size: 12px;\n      color: var(--jam);\n    }\n\n    .splate-body h3 {\n      font-family: 'Marcellus', serif;\n      font-size: clamp(24px, 2.6vw, 34px);\n      line-height: 1.05;\n      margin-top: 8px;\n      transform: translateY(34px) skewY(5deg);\n      opacity: 0;\n      transition: transform .7s cubic-bezier(.2, .8, .2, 1), opacity .7s;\n    }\n\n    .splate.center .splate-body h3 {\n      transform: translateY(0) skewY(0);\n      opacity: 1;\n    }\n\n    .splate-body p {\n      font-size: 15px;\n      line-height: 1.7;\n      color: var(--ink);\n      margin-top: 18px;\n    }\n\n    .splate-body .ess-text::first-letter {\n      font-family: 'Marcellus', serif;\n      font-size: 3.4rem;\n      line-height: 0.8;\n      float: left;\n      padding: 6px 8px 0 0;\n      color: var(--ember);\n    }\n\n    .splate-foot {\n      display: flex;\n      align-items: flex-end;\n      justify-content: space-between;\n      margin-top: 22px;\n      padding-top: 12px;\n      border-top: 1px dashed rgba(122, 90, 69, 0.4);\n    }\n\n    .splate-foot .byline {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.18em;\n      font-size: 12px;\n      color: var(--ink-soft);\n    }\n\n    .stories-rail {\n      flex: 0 0 auto;\n      display: flex;\n      gap: 8px;\n      justify-content: center;\n      padding: 0 40px 34px;\n    }\n\n    .stories-rail span {\n      width: 46px;\n      height: 3px;\n      background: rgba(122, 90, 69, 0.3);\n      transition: background .3s;\n    }\n\n    .stories-rail span.on {\n      background: var(--jam);\n    }\n\n    /* ============ STARTER (#21) ============ */\n    .starter-outer {\n      position: relative;\n      height: 300vh;\n    }\n\n    .spanel {\n      position: sticky;\n      top: 0;\n      height: 100vh;\n      overflow: hidden;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      will-change: transform;\n    }\n\n    .spanel-inner {\n      max-width: 760px;\n      padding: 0 40px;\n      clip-path: inset(0 0 0 0);\n    }\n\n    .spanel .chap-eyebrow {\n      font-style: italic;\n    }\n\n    .spanel h2 {\n      font-family: 'Marcellus', serif;\n      font-size: clamp(38px, 5vw, 64px);\n      line-height: 1.0;\n      margin-top: 6px;\n    }\n\n    .spanel p.body {\n      font-size: 16px;\n      margin-top: 20px;\n      max-width: 34em;\n      margin-left: auto;\n      margin-right: auto;\n    }\n\n    #sp1 {\n      background: var(--cream);\n      z-index: 1;\n      color: var(--ink);\n    }\n\n    #sp2 {\n      background: var(--paper);\n      z-index: 2;\n      color: var(--ink);\n    }\n\n    #sp3 {\n      background: linear-gradient(160deg, var(--ember) 0%, var(--night) 130%);\n      z-index: 3;\n      color: var(--cream);\n    }\n\n    #sp3 .chap-eyebrow {\n      color: #ffd9a3;\n    }\n\n    /* sp2 — specimen plate */\n    #sp2 .spanel-inner {\n      max-width: 1000px;\n      width: 100%;\n    }\n\n    .starter-spec {\n      display: grid;\n      grid-template-columns: 0.82fr 1fr;\n      gap: 64px;\n      align-items: center;\n      text-align: left;\n    }\n\n    .spec-plate {\n      position: relative;\n      background: #FFFDF7;\n      padding: 20px 20px 0;\n      border: 1px solid rgba(58, 36, 26, 0.16);\n      box-shadow: 0 34px 64px -34px rgba(35, 20, 16, 0.55);\n      transform: rotate(-1.8deg);\n    }\n\n    .spec-plate::before,\n    .spec-plate::after {\n      content: \"\";\n      position: absolute;\n      top: -11px;\n      width: 96px;\n      height: 24px;\n      background: rgba(226, 97, 27, 0.62);\n      border-top: 1px dashed rgba(58, 36, 26, 0.4);\n      border-bottom: 1px dashed rgba(58, 36, 26, 0.4);\n    }\n\n    .spec-plate::before {\n      left: 22px;\n      transform: rotate(-4deg);\n    }\n\n    .spec-plate::after {\n      right: 22px;\n      transform: rotate(3.5deg);\n    }\n\n    .spec-jar {\n      position: relative;\n      width: 100%;\n      aspect-ratio: 4 / 5;\n      background: linear-gradient(170deg, #2b1a13 0%, #120b08 100%);\n      overflow: hidden;\n    }\n\n    .spec-jar img {\n      position: relative;\n      z-index: 1;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    .spec-jar .glow {\n      position: absolute;\n      left: 50%;\n      bottom: 18%;\n      width: 62%;\n      height: 42%;\n      transform: translateX(-50%);\n      background: radial-gradient(ellipse at center, rgba(255, 184, 92, 0.55) 0%, transparent 70%);\n      z-index: 0;\n      animation: emberPulse 4.5s ease-in-out infinite;\n    }\n\n    @keyframes emberPulse {\n\n      0%,\n      100% {\n        opacity: 0.55;\n        transform: translateX(-50%) scale(1);\n      }\n\n      50% {\n        opacity: 0.9;\n        transform: translateX(-50%) scale(1.08);\n      }\n    }\n\n    .spec-cap {\n      display: flex;\n      align-items: baseline;\n      justify-content: space-between;\n      gap: 16px;\n      padding: 12px 2px 14px;\n    }\n\n    .spec-cap .cn {\n      font-family: 'Marcellus', serif;\n      font-size: 16px;\n      color: var(--ink);\n    }\n\n    .spec-cap .cm {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.2em;\n      font-size: 11px;\n      color: var(--ink-soft);\n      white-space: nowrap;\n    }\n\n    .spec-body .legacy {\n      margin: 4px 0 0;\n    }\n\n    .spec-intro {\n      font-size: 16px;\n      color: var(--ink);\n      max-width: 30em;\n    }\n\n    .spec-list {\n      list-style: none;\n      margin-top: 26px;\n      border-top: 1px solid rgba(122, 90, 69, 0.2);\n    }\n\n    .spec-list li {\n      display: flex;\n      align-items: baseline;\n      justify-content: space-between;\n      gap: 24px;\n      padding: 12px 2px;\n      border-bottom: 1px dashed rgba(122, 90, 69, 0.34);\n    }\n\n    .spec-list .k {\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.2em;\n      font-size: 11.5px;\n      color: var(--ink-soft);\n    }\n\n    .spec-list .v {\n      font-family: 'Marcellus', serif;\n      font-size: 18px;\n      color: var(--ink);\n    }\n\n    .jar-bubbles span {\n      position: absolute;\n      bottom: 22%;\n      z-index: 2;\n      width: 7px;\n      height: 7px;\n      border-radius: 50%;\n      background: rgba(255, 198, 120, 0.85);\n      animation: bub 4s linear infinite;\n    }\n\n    @keyframes bub {\n      0% {\n        transform: translateY(0);\n        opacity: 0;\n      }\n\n      20% {\n        opacity: 1;\n      }\n\n      100% {\n        transform: translateY(-150px);\n        opacity: 0;\n      }\n    }\n\n    .legacy {\n      font-family: 'Caveat', cursive;\n      font-size: clamp(48px, 6vw, 76px);\n      color: var(--jam);\n      margin-top: 18px;\n      line-height: 0.9;\n    }\n\n    #starter-cta {\n      position: relative;\n      margin-top: 30px;\n      background: var(--jam);\n      color: var(--cream);\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.25em;\n      font-size: 13px;\n      font-weight: 500;\n      border: none;\n      cursor: pointer;\n      padding: 18px 40px;\n      border-radius: 999px;\n      transition: transform .25s, background .25s;\n    }\n\n    #starter-cta:hover {\n      transform: translateY(-3px);\n      background: #fff;\n      color: var(--jam);\n    }\n\n    #starter-cta:focus-visible {\n      outline: 3px solid #ffd9a3;\n      outline-offset: 3px;\n    }\n\n    .particle {\n      position: absolute;\n      width: 7px;\n      height: 7px;\n      border-radius: 50%;\n      background: #fff;\n      pointer-events: none;\n      left: 50%;\n      top: 50%;\n    }\n\n    .pg47 {\n      margin-top: 26px;\n      font-size: 15px;\n    }\n\n    #sp3 .pg47 {\n      color: #ffd9a3;\n    }\n\n    /* ============ FOOTER ============ */\n    footer {\n      position: relative;\n      padding: 72px 0 40px;\n      border-top: 1px dashed rgba(122, 90, 69, 0.4);\n    }\n\n    .foot-grid {\n      display: flex;\n      flex-wrap: wrap;\n      align-items: flex-end;\n      justify-content: space-between;\n      gap: 36px;\n    }\n\n    .foot-brand .fmark {\n      font-family: 'Marcellus', serif;\n      font-size: 38px;\n      color: var(--jam);\n      line-height: 1;\n    }\n\n    .foot-brand .fflour {\n      font-family: 'Caveat', cursive;\n      font-size: 24px;\n      color: var(--ember);\n    }\n\n    .foot-brand .label {\n      margin-top: 12px;\n      display: block;\n    }\n\n    .foot-cols {\n      display: flex;\n      gap: 48px;\n    }\n\n    .foot-col {\n      transform: translateY(20px);\n      opacity: 0;\n      transition: transform .6s cubic-bezier(.2, .8, .2, 1), opacity .6s;\n      transition-delay: calc(var(--c)*80ms);\n    }\n\n    .foot-col.in {\n      transform: translateY(0);\n      opacity: 1;\n    }\n\n    .foot-col h4 {\n      font-family: 'Spectral', serif;\n      font-style: italic;\n      color: var(--ink);\n      margin-bottom: 8px;\n    }\n\n    .foot-col a {\n      display: block;\n      font-family: 'Spectral', serif;\n      text-transform: uppercase;\n      letter-spacing: 0.14em;\n      font-size: 12px;\n      color: var(--ink-soft);\n      padding: 3px 0;\n      transition: color .25s;\n    }\n\n    .foot-col a:hover {\n      color: var(--jam);\n    }\n\n    .foot-rule {\n      margin-top: 40px;\n    }\n\n    .foot-rule path {\n      stroke: var(--jam);\n      stroke-width: 1.6;\n      fill: none;\n      stroke-linecap: round;\n      stroke-dasharray: 1200;\n      stroke-dashoffset: 1200;\n      transition: stroke-dashoffset 1.6s ease;\n    }\n\n    .foot-rule.in path {\n      stroke-dashoffset: 0;\n    }\n\n    .foot-tag {\n      text-align: center;\n      margin-top: 18px;\n      font-style: italic;\n    }\n\n    /* ============ RESPONSIVE ============ */\n    @media (max-width:768px) {\n      .wrap {\n        padding: 0 22px;\n      }\n\n      .brand .b1 {\n        font-size: 32px;\n      }\n\n      .brand .b2 {\n        font-size: 22px;\n      }\n\n      .nav {\n        display: none;\n      }\n\n      .hero-frame {\n        margin-left: 0;\n        width: calc(100vw - 36px);\n        margin: 0 18px;\n        padding: 34px 26px 32px;\n      }\n\n      .shelf-head {\n        flex-direction: column;\n        align-items: flex-start;\n      }\n\n      .shelf-head .freshly {\n        text-align: left;\n      }\n\n      .recitem {\n        flex-direction: column;\n        gap: 6px;\n        align-items: flex-start;\n      }\n\n      .recitem .rtitle {\n        font-size: 30px;\n      }\n\n      .preview {\n        display: none;\n      }\n\n      /* Season: drop pin -> stacked static blocks */\n      .season-outer {\n        height: auto;\n      }\n\n      .season-sticky {\n        position: relative;\n        height: auto;\n        display: block;\n        background: var(--cream);\n        color: var(--ink);\n      }\n\n      .season-stage {\n        height: auto;\n      }\n\n      .season-pane {\n        position: relative;\n        inset: auto;\n        opacity: 1;\n        filter: none;\n        padding: 70px 22px;\n        min-height: 60vh;\n        justify-content: center;\n      }\n\n      .sun-arc {\n        display: none;\n      }\n\n      .season-prog {\n        display: none;\n      }\n\n      .season-pane.m-spring {\n        background: #f7e6df;\n      }\n\n      .season-pane.m-summer {\n        background: #fbf3df;\n      }\n\n      .season-pane.m-autumn {\n        background: #caa06f;\n        color: #fff;\n      }\n\n      .season-pane.m-winter {\n        background: var(--night);\n        color: var(--cream);\n      }\n\n      .season-pane.m-autumn .snum,\n      .season-pane.m-winter .snum {\n        color: var(--ember);\n      }\n\n      /* Stories: drop pin -> vertical snap */\n      .stories-outer {\n        height: auto;\n      }\n\n      .stories-sticky {\n        position: relative;\n        height: auto;\n      }\n\n      .stories-track {\n        overflow: visible;\n      }\n\n      .stories-strip {\n        flex-direction: column;\n        width: 100%;\n      }\n\n      .splate {\n        width: 100%;\n        flex: none;\n        padding: 30px 22px;\n      }\n\n      .splate-card {\n        grid-template-columns: 1fr;\n        gap: 22px;\n        padding: 28px;\n        transform: none;\n      }\n\n      .splate-body h3 {\n        transform: none;\n        opacity: 1;\n      }\n\n      .stories-rail {\n        display: none;\n      }\n\n      /* Starter: drop sticky stacking */\n      .starter-outer {\n        height: auto;\n      }\n\n      .spanel {\n        position: relative;\n        height: auto;\n        min-height: 80vh;\n        padding: 70px 0;\n      }\n\n      .starter-spec {\n        grid-template-columns: 1fr;\n        gap: 40px;\n        text-align: center;\n      }\n\n      .spec-plate {\n        max-width: 320px;\n        margin: 0 auto;\n        transform: rotate(-1.4deg);\n      }\n\n      .spec-body {\n        text-align: center;\n      }\n\n      .spec-body .rule {\n        margin-left: auto !important;\n        margin-right: auto !important;\n      }\n\n      .spec-intro {\n        margin: 0 auto;\n      }\n\n      .spec-list .v {\n        font-size: 16px;\n      }\n\n      .foot-grid {\n        flex-direction: column;\n        align-items: flex-start;\n      }\n\n      .foot-cols {\n        flex-wrap: wrap;\n        gap: 30px;\n      }\n    }\n\n      </style>\n<link     href=\"https://fonts.googleapis.com/css2?family=Marcellus&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Caveat:wght@500;600&display=swap\"\n    rel=\"stylesheet\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n\n\n  \n  <div class=\"preview\" id=\"preview\" aria-hidden=\"true\" data-kid=\"0\">\n    <img id=\"preview-img\" alt onerror=\"this.style.display='none'\" data-kid=\"1\">\n    <div class=\"ptext\" id=\"preview-text\" style=\"display:none;\" data-kid=\"2\"></div>\n  </div>\n\n  \n  <header class=\"hero\" data-kid=\"3\">\n    <div class=\"hero-bg\" data-kid=\"4\"></div>\n    <video class=\"hero-vid\" id=\"hero-vid\" autoplay loop muted playsinline poster=\"https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_ar