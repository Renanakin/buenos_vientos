ath d=\"M13 2 Q12 18 13 34\" data-kid=\"29\"></path>\n        <path d=\"M5 26 Q12 36 13 36 Q14 36 21 26\" data-kid=\"30\"></path>\n      </svg>\n    </div>\n  </header>\n\n  <div class=\"gingham\" data-kid=\"31\"></div>\n\n  \n  <section class=\"shelf\" id=\"shelf\" data-kid=\"32\">\n    <div class=\"wrap\" data-kid=\"33\">\n      <div class=\"shelf-head\" id=\"shelf-head\" data-kid=\"34\">\n        <div data-kid=\"35\">\n          <p class=\"chap-eyebrow\" data-kid=\"36\">Chapter I.</p>\n          <h2 class=\"chap-title\" data-kid=\"37\"><span class=\"linereveal\" id=\"shelf-title\" data-kid=\"38\">This Week's <em data-kid=\"39\">Shelf</em></span></h2>\n        </div>\n        <p class=\"freshly script\" data-kid=\"40\"><span class=\"a\" data-kid=\"41\">freshly pulled,</span><span class=\"b\" data-kid=\"42\">still warm —</span></p>\n      </div>\n\n      <div class=\"tabs\" id=\"tabs\" role=\"tablist\" data-kid=\"43\">\n        <button class=\"tab active\" data-cat=\"0\" role=\"tab\" data-kid=\"44\">Breads</button>\n        <button class=\"tab\" data-cat=\"1\" role=\"tab\" data-kid=\"45\">Preserves</button>\n        <button class=\"tab\" data-cat=\"2\" role=\"tab\" data-kid=\"46\">Pies</button>\n        <button class=\"tab\" data-cat=\"3\" role=\"tab\" data-kid=\"47\">Cakes</button>\n        <button class=\"tab\" data-cat=\"4\" role=\"tab\" data-kid=\"48\">Biscuits</button>\n        <button class=\"tab\" data-cat=\"5\" role=\"tab\" data-kid=\"49\">Gatherings</button>\n      </div>\n\n      <div class=\"reclist\" id=\"reclist\" data-kid=\"50\"></div>\n    </div>\n  </section>\n\n  <div class=\"gingham\" data-kid=\"51\"></div>\n\n  \n  <section id=\"seasons\" data-kid=\"52\">\n    <div class=\"wrap season-intro\" data-kid=\"53\">\n      <div class=\"season-intro-grid\" data-kid=\"54\">\n        <div data-kid=\"55\">\n          <p class=\"chap-eyebrow\" data-kid=\"56\">Chapter II.</p>\n          <h2 class=\"chap-title\" data-kid=\"57\"><span class=\"linereveal\" id=\"season-title\" data-kid=\"58\">By the <em data-kid=\"59\">Season</em></span></h2>\n          <div class=\"rule\" style=\"width:200px;margin-top:14px;\" data-kid=\"60\"></div>\n        </div>\n        <p class=\"lead\" data-kid=\"61\">We cook the year as it comes. Browse the bakehouse by what's at the market, what's in the\n          garden, what's stored down in the cellar.</p>\n      </div>\n    </div>\n\n    <div class=\"season-outer\" id=\"season-outer\" data-kid=\"62\">\n      <div class=\"season-sticky\" id=\"season-sticky\" data-kid=\"63\">\n        <svg class=\"sun-arc\" id=\"sun-arc\" viewBox=\"0 0 1000 600\" preserveAspectRatio=\"none\" aria-hidden=\"true\" data-kid=\"64\">\n          <circle class=\"sun-dot\" id=\"sun-dot\" cx=\"120\" cy=\"520\" r=\"22\" data-kid=\"65\"></circle>\n        </svg>\n        <div class=\"season-stage\" data-kid=\"66\">\n          <div class=\"season-pane active m-spring\" data-i=\"0\" data-kid=\"67\">\n            <img class=\"season-img\" src=\"https://images.unsplash.com/photo-1490818387583-1baba5e638af?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwyMHx8cmh1YmFyYiUyMGVsZGVyZmxvd2VyJTIwc3ByaW5nJTIwYmFraW5nJTIwaW5ncmVkaWVudHMlMjBvdmVyaGVhZCUyMHN0aWxsJTIwbGlmZSUyMHdhcm0lMjB0b25lc3xlbnwwfDB8fHwxNzc5ODk0ODY4fDA&ixlib=rb-4.1.0&q=85\" alt=\"Spring ingredients — Photo by Brooke Lark\" loading=\"lazy\" data-kid=\"68\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n            <p class=\"snum\" data-kid=\"69\">i.</p>\n            <h3 class=\"disp\" data-kid=\"70\">Spring</h3>\n            <p class=\"sing\" data-kid=\"71\">rhubarb · elderflower · curd</p>\n          </div>\n          <div class=\"season-pane m-summer\" data-i=\"1\" data-kid=\"72\">\n            <img class=\"season-img\" src=\"https://images.pexels.com/photos/17356990/pexels-photo-17356990.jpeg\" alt=\"Summer peach tart — Photo by Beyza\" loading=\"lazy\" data-kid=\"73\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n            <p class=\"snum\" data-kid=\"74\">ii.</p>\n            <h3 class=\"disp\" data-kid=\"75\">Summer</h3>\n            <p class=\"sing\" data-kid=\"76\">stone fruit · berry · honey</p>\n          </div>\n          <div class=\"season-pane m-autumn\" data-i=\"2\" data-kid=\"77\">\n            <img class=\"season-img\" src=\"https://images.pexels.com/photos/5662080/pexels-photo-5662080.jpeg\" alt=\"Autumn apple cake — Photo by KATRIN BOLOVTSOVA\" loading=\"lazy\" data-kid=\"78\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n            <p class=\"snum\" data-kid=\"79\">iii.</p>\n            <h3 class=\"disp\" data-kid=\"80\">Autumn</h3>\n            <p class=\"sing\" data-kid=\"81\">apple · walnut · spice</p>\n          </div>\n          <div class=\"season-pane m-winter\" data-i=\"3\" data-kid=\"82\">\n            <img class=\"season-img\" src=\"https://images.pexels.com/photos/5702755/pexels-photo-5702755.jpeg\" alt=\"Winter gingerbread — Photo by KATRIN BOLOVTSOVA\" loading=\"lazy\" data-kid=\"83\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n            <p class=\"snum\" data-kid=\"84\">iv.</p>\n            <h3 class=\"disp\" data-kid=\"85\">Winter</h3>\n            <p class=\"sing\" data-kid=\"86\">citrus · cardamom · hearth</p>\n          </div>\n        </div>\n        <div class=\"season-prog\" id=\"season-prog\" data-kid=\"87\">\n          <span class=\"on\" data-kid=\"88\"></span><span data-kid=\"89\"></span><span data-kid=\"90\"></span><span data-kid=\"91\"></span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"gingham\" data-kid=\"92\"></div>\n\n  \n  <section id=\"stories\" data-kid=\"93\">\n    <div class=\"stories-outer\" id=\"stories-outer\" data-kid=\"94\">\n      <div class=\"stories-sticky\" data-kid=\"95\">\n        <div class=\"stories-head\" data-kid=\"96\">\n          <div data-kid=\"97\">\n            <p class=\"chap-eyebrow\" data-kid=\"98\">Chapter III.</p>\n            <h2 class=\"chap-title\" data-kid=\"99\"><span class=\"linereveal\" id=\"stories-title\" data-kid=\"100\">Stories from <em data-kid=\"101\">the Kitchen</em></span>\n            </h2>\n          </div>\n          <p class=\"sideways script\" data-kid=\"102\">scroll sideways →</p>\n        </div>\n\n        <div class=\"stories-track\" data-kid=\"103\">\n          <div class=\"stories-strip\" id=\"stories-strip\" data-kid=\"104\">\n            \n            <div class=\"splate\" data-i=\"0\" data-kid=\"105\">\n              <article class=\"splate-card\" data-kid=\"106\">\n                <div class=\"splate-portrait\" style=\"background:var(--jam);\" data-kid=\"107\">\n                  <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/stories/portrait-01.png\" alt=\"Portrait of Mira Halvorsen\" loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"108\">\n                </div>\n                <div class=\"splate-body\" data-kid=\"109\">\n                  <p class=\"ess-num\" data-kid=\"110\">Essay № 01</p>\n                  <h3 class=\"disp\" data-kid=\"111\">My Grandmother's <em data-kid=\"112\">Saturday Rye</em></h3>\n                  <p class=\"ess-text\" data-kid=\"113\">Every Saturday before sunrise, she would wake the starter the way one wakes a\n                    child — gently, with warm hands and quiet talking. I learned to bake before I learned to read, and I\n                    am still grateful for the order in which those things came.</p>\n                  <div class=\"splate-foot\" data-kid=\"114\">\n                    <p class=\"byline\" data-kid=\"115\">Mira Halvorsen · Oslo</p>\n                    <span class=\"pgnum\" data-kid=\"116\">Pg. 14</span>\n                  </div>\n                </div>\n              </article>\n            </div>\n            \n            <div class=\"splate\" data-i=\"1\" data-kid=\"117\">\n              <article class=\"splate-card\" data-kid=\"118\">\n                <div class=\"splate-portrait\" style=\"background:var(--ember);\" data-kid=\"119\">\n                  <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/stories/portrait-02.png\" alt=\"Portrait of Beatrice Okafor\" loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"120\">\n                </div>\n                <div class=\"splate-body\" data-kid=\"121\">\n                  <p class=\"ess-num\" data-kid=\"122\">Essay № 02</p>\n                  <h3 class=\"disp\" data-kid=\"123\">Pies in a House <em data-kid=\"124\">of Five Sisters</em></h3>\n                  <p class=\"ess-text\" data-kid=\"125\">We did not own a rolling pin until I was eleven. Before that, my mother used the\n                    curve of a wine bottle and the flat of her palm. The pies were better then — or perhaps it is only\n                    that we were younger, and the kitchen was small.</p>\n                  <div class=\"splate-foot\" data-kid=\"126\">\n                    <p class=\"byline\" data-kid=\"127\">Beatrice Okafor · Cork</p>\n                    <span class=\"pgnum\" data-kid=\"128\">Pg. 22</span>\n                  </div>\n                </div>\n              </article>\n            </div>\n            \n            <div class=\"splate\" data-i=\"2\" data-kid=\"129\">\n              <article class=\"splate-card\" data-kid=\"130\">\n                <div class=\"splate-portrait\" style=\"background:var(--jam);\" data-kid=\"131\">\n                  <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/stories/portrait-03.png\" alt=\"Portrait of Sven Lindqvist\" loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"132\">\n                </div>\n                <div class=\"splate-body\" data-kid=\"133\">\n                  <p class=\"ess-num\" data-kid=\"134\">Essay № 03</p>\n                  <h3 class=\"disp\" data-kid=\"135\">The Cardamom Bun, <em data-kid=\"136\">and Other Inheritances</em></h3>\n                  <p class=\"ess-text\" data-kid=\"137\">A recipe is a small inheritance. It comes from no will, no notary; it travels in\n                    the back of cookbooks, on index cards, on the inside of a cupboard door. I keep ours pinned above\n                    the oven where the steam can soften the paper.</p>\n                  <div class=\"splate-foot\" data-kid=\"138\">\n                    <p class=\"byline\" data-kid=\"139\">Sven Lindqvist · Malmö</p>\n                    <span class=\"pgnum\" data-kid=\"140\">Pg. 31</span>\n                  </div>\n                </div>\n              </article>\n            </div>\n            \n            <div class=\"splate\" data-i=\"3\" data-kid=\"141\">\n              <article class=\"splate-card\" data-kid=\"142\">\n                <div class=\"splate-portrait\" style=\"background:var(--ember);\" data-kid=\"143\">\n                  <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/stories/portrait-04.png\" alt=\"Portrait of Agnes Whitcombe\" loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"144\">\n                </div>\n                <div class=\"splate-body\" data-kid=\"145\">\n                  <p class=\"ess-num\" data-kid=\"146\">Essay № 04</p>\n                  <h3 class=\"disp\" data-kid=\"147\">Of Damson Jam <em data-kid=\"148\">and August Light</em></h3>\n                  <p class=\"ess-text\" data-kid=\"149\">The smell of plums collapsing in the pan is the closest thing I have to a season I\n                    can hold. I bottle as many jars as the cupboard will take, and I label them in pencil so the year\n                    can fade.</p>\n                  <div class=\"splate-foot\" data-kid=\"150\">\n                    <p class=\"byline\" data-kid=\"151\">Agnes Whitcombe · Devon</p>\n                    <span class=\"pgnum\" data-kid=\"152\">Pg. 38</span>\n                  </div>\n                </div>\n              </article>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"stories-rail\" id=\"stories-rail\" data-kid=\"153\">\n          <span class=\"on\" data-kid=\"154\"></span><span data-kid=\"155\"></span><span data-kid=\"156\"></span><span data-kid=\"157\"></span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"gingham\" data-kid=\"158\"></div>\n\n  \n  <section id=\"starters\" data-kid=\"159\">\n    <div class=\"starter-outer\" id=\"starter-outer\" data-kid=\"160\">\n      <div class=\"spanel\" id=\"sp1\" data-kid=\"161\">\n        <div class=\"spanel-inner\" data-kid=\"162\">\n          <p class=\"chap-eyebrow\" data-kid=\"163\">Chapter IV.</p>\n          <h2 class=\"disp\" data-kid=\"164\">The <em data-kid=\"165\">Starter</em> Library</h2>\n          <div class=\"rule\" style=\"width:200px;margin:18px auto;\" data-kid=\"166\"></div>\n          <p class=\"body\" data-kid=\"167\">A living archive of sourdoughs, kefirs, and ginger bugs — each with a name, a lineage, and a\n            baker who tends it. Begin yours today, and pass it on tomorrow.</p>\n        </div>\n      </div>\n      <div class=\"spanel\" id=\"sp2\" data-kid=\"168\">\n        <div class=\"spanel-inner\" data-kid=\"169\">\n          <div class=\"starter-spec\" data-kid=\"170\">\n            <figure class=\"spec-plate\" data-kid=\"171\">\n              <div class=\"spec-jar\" data-kid=\"172\">\n                <span class=\"glow\" data-kid=\"173\"></span>\n                <div class=\"jar-bubbles\" data-kid=\"174\">\n                  <span style=\"left:40%;animation-delay:0s;\" data-kid=\"175\"></span>\n                  <span style=\"left:56%;animation-delay:1.1s;\" data-kid=\"176\"></span>\n                  <span style=\"left:66%;animation-delay:2.2s;\" data-kid=\"177\"></span>\n                  <span style=\"left:48%;animation-delay:3s;\" data-kid=\"178\"></span>\n                </div>\n                <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/starter/jar.png\" alt=\"A glowing jar of sourdough starter, No. 1842\" onerror=\"this.style.display='none'\" data-kid=\"179\">\n              </div>\n              <figcaption class=\"spec-cap\" data-kid=\"180\">\n                <span class=\"cn\" data-kid=\"181\">Heritage Starter <em data-kid=\"182\">№ 1842</em></span>\n                <span class=\"cm\" data-kid=\"183\">live culture</span>\n              </figcaption>\n            </figure>\n            <div class=\"spec-body\" data-kid=\"184\">\n              <p class=\"chap-eyebrow\" data-kid=\"185\">— a living thing —</p>\n              <p class=\"legacy\" data-kid=\"186\">Begin your legacy.</p>\n              <div class=\"rule\" style=\"width:200px;margin:14px 0 22px;\" data-kid=\"187\"></div>\n              <p class=\"spec-intro\" data-kid=\"188\">Take a spoonful of a culture first raised in 1842. Feed it, name it, and one day\n                hand it down — still rising.</p>\n              <ul class=\"spec-list\" data-kid=\"189\">\n                <li data-kid=\"190\"><span class=\"k\" data-kid=\"191\">Born</span><span class=\"v\" data-kid=\"192\">1842 · Yorkshire</span></li>\n                <li data-kid=\"193\"><span class=\"k\" data-kid=\"194\">Fed</span><span class=\"v\" data-kid=\"195\">daily, with rye</span></li>\n                <li data-kid=\"196\"><span class=\"k\" data-kid=\"197\">Tended by</span><span class=\"v\" data-kid=\"198\">four generations</span></li>\n                <li data-kid=\"199\"><span class=\"k\" data-kid=\"200\">Status</span><span class=\"v\" data-kid=\"201\"><em data-kid=\"202\">still alive</em></span></li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"spanel\" id=\"sp3\" data-kid=\"203\">\n        <div class=\"spanel-inner\" data-kid=\"204\">\n          <p class=\"chap-eyebrow\" data-kid=\"205\">— a small inheritance —</p>\n          <h2 class=\"disp\" data-kid=\"206\">Start a jar. <em style=\"color:#ffd9a3;\" data-kid=\"207\">Tend the line.</em></h2>\n          <button id=\"starter-cta\" data-kid=\"208\">Add a Starter</button>\n          <p class=\"pg47 pgnum\" data-kid=\"209\">— Pg. 47 —</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"gingham\" data-kid=\"210\"></div>\n\n  \n  <footer data-kid=\"211\">\n    <div class=\"wrap\" data-kid=\"212\">\n      <div class=\"foot-grid\" data-kid=\"213\">\n        <div class=\"foot-brand\" data-kid=\"214\">\n          <div class=\"fmark disp\" data-kid=\"215\">Heritage <span class=\"fflour\" data-kid=\"216\">Bakehouse</span></div>\n          <span class=\"label\" data-kid=\"217\">est. MMXXV · a small community press</span>\n        </div>\n        <div class=\"foot-cols\" id=\"foot-cols\" data-kid=\"218\">\n          <div class=\"foot-col\" style=\"--c:0\" data-kid=\"219\">\n            <h4 data-kid=\"220\">The Library</h4>\n            <a href=\"#\" data-kid=\"221\">Recipes</a><a href=\"#\" data-kid=\"222\">Starters</a><a href=\"#\" data-kid=\"223\">Seasons</a>\n          </div>\n          <div class=\"foot-col\" style=\"--c:1\" data-kid=\"224\">\n            <h4 data-kid=\"225\">The Folk</h4>\n            <a href=\"#\" data-kid=\"226\">Bakers</a><a href=\"#\" data-kid=\"227\">Stories</a><a href=\"#\" data-kid=\"228\">Contribute</a>\n          </div>\n          <div class=\"foot-col\" style=\"--c:2\" data-kid=\"229\">\n            <h4 data-kid=\"230\">The Post</h4>\n            <a href=\"#\" data-kid=\"231\">Monthly letter</a><a href=\"#\" data-kid=\"232\">Mended pages</a>\n          </div>\n        </div>\n      </div>\n      <svg class=\"foot-rule\" id=\"foot-rule\" viewBox=\"0 0 1100 8\" preserveAspectRatio=\"none\" height=\"8\" width=\"100%\" data-kid=\"233\">\n        <path d=\"M2 4 C 180 1, 360 7, 550 3 S 920 6, 1098 4\" data-kid=\"234\"></path>\n      </svg>\n      <p class=\"foot-tag pgnum\" data-kid=\"235\">~ flour, salt, water, time ~</p>\n    </div>\n  </footer>\n\n  <script data-kid=\"236\">\n    (function () {\n      var mobile = function () { return window.matchMedia('(max-width:768px)').matches; };\n\n      /* ---- page loaded class + hero per-word split ---- */\n      var h1 = document.getElementById('hero-h1');\n      var words = \"A Quiet Kitchen, an Honest Loaf.\".split(' ');\n      var html = '';\n      words.forEach(function (w, i) {\n        var jam = (w === 'Honest' || w === 'Loaf.');\n        html += '<span class=\"w\" style=\"--i:' + i + ';' + (jam ? 'color:var(--jam);' : '') + '\">' + w + '</span>' + (i < words.length - 1 ? ' ' : '');\n      });\n      h1.innerHTML = html;\n      requestAnimationFrame(function () { document.body.classList.add('loaded'); });\n\n      /* ---- recipe deck data (verbatim from source) ---- */\n      var categories = {\n        0: {\n          name: 'Breads', items: [\n            { title: 'Saturday Morning Rye', meta: 'Mira H. · 18 hrs', img: 'https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/shelf/rye.png' },\n            { title: 'Wild Oat Sourdough', meta: 'Tomas K. · 2 days', img: 'https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/shelf/sourdough.png' },\n            { title: 'Buttermilk Soda Bread', meta: 'Niamh O. · 1 hr', img: 'https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/shelf/soda.png' },\n            { title: 'Pain de Campagne', meta: 'Élise R. · 24 hrs', img: 'https://kombai-assets-dev.b-cdn.net/generated_assets/11_landing_page_for_a_heritage_artisan_bakehouse/assets/shelf/campagne.png' }]\n        },\n        1: {\n          name: 'Preserves', items: [\n            { title: 'Damson Plum Jam', meta: 'Agnes W. · August' },\n            { title: 'Spiced Apple Butter', meta: 'Beatrice O. · October' },\n            { title: 'Quince Membrillo', meta: 'Carmen V. · November' },\n            { title: 'Elderflower Cordial', meta: 'June P. · May' }]\n        },\n        2: {\n          name: 'Pies', items: [\n            { title: 'Bramley Apple & Walnut', meta: 'Eleanor F. · autumn' },\n            { title: 'Rhubarb Custard Tart', meta: 'Lila B. · spring' },\n            { title: 'Black Bottom Pecan', meta: 'Ada S. · winter' },\n            { title: 'Cherry Lattice', meta: 'Henrik J. · summer' }]\n        },\n        3: {\n          name: 'Cakes', items: [\n            { title: 'Lemon Olive Oil Cake', meta: 'Sofia M. · sunday' },\n            { title: 'Honey & Almond Loaf', meta: 'Yusuf D. · weekday' },\n            { title: 'Black Treacle Gingerbread', meta: 'Maud L. · advent' },\n            { title: 'Strawberry Victoria', meta: 'Margaret C. · june' }]\n        },\n        4: {\n          name: 'Biscuits', items: [\n            { title: 'Cardamom Shortbread', meta: 'Sven L. · weekly' },\n            { title: 'Oat & Treacle Biscuits', meta: 'Donald M. · saturday' },\n            { title: 'Almond Tuiles', meta: 'Camille A. · holiday' },\n            { title: 'Hazelnut Florentines', meta: 'Pia B. · christmas' }]\n        },\n        5: {\n          name: 'Gatherings', items: [\n            { title: 'A Harvest Supper', meta: '8 dishes · serves 12' },\n            { title: 'A Quiet Christmas Eve', meta: '5 dishes · serves 6' },\n            { title: 'Midsummer Picnic Box', meta: '7 dishes · serves 10' },\n            { title: 'A Sunday Tea', meta: '4 dishes · serves 4' }]\n        }\n      };\n\n      var reclist = document.getElementById('reclist');\n      var preview = document.getElementById('preview');\n      var previewImg = document.getElementById('preview-img');\n      var previewText = document.getElementById('preview-text');\n      var activePreview = null;\n\n      function renderDeck(catIdx) {\n        var items = categories[catIdx].items;\n        reclist.innerHTML = '';\n        items.forEach(function (it, i) {\n          var row = document.createElement('div');\n          row.className = 'recitem';\n          row.innerHTML = '<span class=\"rtitle\"><span class=\"recnum\">№ ' + String(i + 1).padStart(2, '0') + '</span>' + it.title + '</span>' +\n            '<span class=\"rmeta\">' + it.meta + '</span>';\n          row.dataset.img = it.img || '';\n          row.dataset.title = it.title;\n          row.dataset.meta = it.meta;\n          reclist.appendChild(row);\n          // staggered entrance\n          setTimeout(function () { row.classList.add('in'); }, 60 * i);\n\n          row.addEventListener('pointerenter', function () {\n            if (mobile()) return;\n            if (it.img) {\n              previewImg.src = it.img;\n              previewImg.alt = it.title;\n              previewImg.style.display = 'block';\n              previewText.style.display = 'none';\n            } else {\n              previewImg.style.display = 'none';\n              previewText.style.display = 'flex';\n              previewText.innerHTML = '<span class=\"pt-title\">' + it.title + '</span><span class=\"pt-meta\">' + it.meta + '</span>';\n            }\n            preview.classList.add('show');\n            activePreview = true;\n          });\n          row.addEventListener('pointerleave', function () {\n            preview.classList.remove('show');\n            activePreview = false;\n          });\n        });\n      }\n      renderDeck(0);\n\n      document.querySelectorAll('#tabs .tab').forEach(function (btn) {\n        btn.addEventListener('click', function () {\n          document.querySelectorAll('#tabs .tab').forEach(function (b) { b.classList.remove('active'); });\n          btn.classList.add('active');\n          renderDeck(parseInt(btn.dataset.cat, 10));\n        });\n      });\n\n      // cursor preview tracking (rAF throttled)\n      var px = 0, py = 0, ptick = false;\n      window.addEventListener('pointermove', function (e) {\n        px = e.clientX; py = e.clientY;\n        if (!ptick && activePreview) {\n          requestAnimationFrame(function () {\n            preview.style.left = px + 'px';\n            preview.style.top = py + 'px';\n            ptick = false;\n          });\n          ptick = true;\n        }\n      }, { passive: true });\n\n      /* ---- heading line-reveals on enter ---- */\n      if ('IntersectionObserver' in window) {\n        var io = new IntersectionObserver(function (entries) {\n          entries.forEach(function (en) { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });\n        }, { threshold: 0.4 });\n        ['shelf-title', 'season-title', 'stories-title'].forEach(function (id) { var el = document.getElementById(id); if (el) io.observe(el); });\n\n        // footer cols + rule\n        var fcols = document.getElementById('foot-cols');\n        var frule = document.getElementById('foot-rule');\n        var fio = new IntersectionObserver(function (entries) {\n          entries.forEach(function (en) {\n            if (en.isIntersecting) {\n              document.querySelectorAll('.foot-col').forEach(function (c) { c.classList.add('in'); });\n              frule.classList.add('in');\n              fio.disconnect();\n            }\n          });\n        }, { threshold: 0.3 });\n        if (fcols) fio.observe(fcols);\n      }\n\n      /* ---- SEASON inversion color stops (dawn->noon->dusk->night) ---- */\n      // [bg, text, accent]\n      var seasonStops = [\n        ['#F7E6DF', '#3A241A', '#C81E37'], // Spring - dawn\n        ['#FBF3DF', '#3A241A', '#E2611B'], // Summer - noon\n        ['#CAA06F', '#FBF4E6', '#E2611B'], // Autumn - dusk\n        ['#231410', '#F3EADA', '#C81E37']  // Winter - night\n      ];\n      function hexToRgb(h) { h = h.replace('#', ''); return [parseInt(h.substr(0, 2), 16), parseInt(h.substr(2, 2), 16), parseInt(h.substr(4, 2), 16)]; }\n      function lerp(a, b, t) { return Math.round(a + (b - a) * t); }\n      function mix(c1, c2, t) { var a = hexToRgb(c1), b = hexToRgb(c2); return 'rgb(' + lerp(a[0], b[0], t) + ',' + lerp(a[1], b[1], t) + ',' + lerp(a[2], b[2], t) + ')'; }\n\n      var seasonOuter = document.getElementById('season-outer');\n      var seasonSticky = document.getElementById('season-sticky');\n      var panes = document.querySelectorAll('.season-pane');\n      var seasonProg = document.getElementById('season-prog').children;\n      var sunDot = document.getElementById('sun-dot');\n\n      function updateSeason() {\n        if (mobile() || !seasonOuter) return;\n        var r = seasonOuter.getBoundingClientRect();\n        var total = seasonOuter.offsetHeight - window.innerHeight;\n        var p = Math.min(1, Math.max(0, (-r.top) / total)); // 0..1\n        // 4 stops -> 3 segments\n        var seg = p * 3;\n        var idx = Math.min(2, Math.floor(seg));\n        var t = seg - idx;\n        var s1 = seasonStops[idx], s2 = seasonStops[idx + 1];\n        var bg = mix(s1[0], s2[0], t);\n        seasonSticky.style.background = bg;\n        seasonSticky.style.setProperty('--inv-bg', bg);\n        seasonSticky.style.color = mix(s1[1], s2[1], t);\n        var accent = mix(s1[2], s2[2], t);\n        seasonSticky.style.setProperty('--inv-accent', accent);\n        // active pane (nearest)\n        var activeIdx = Math.round(p * 3);\n        panes.forEach(function (pane, i) { pane.classList.toggle('active', i === activeIdx); });\n        for (var i = 0; i < seasonProg.length; i++) { seasonProg[i].classList.toggle('on', i <= activeIdx); }\n        // sun arc: rises then sets across the frame\n        var w = window.innerWidth, h = window.innerHeight;\n        var x = 120 + p * (1000 - 240);\n        var y = 520 - Math.sin(p * Math.PI) * 440; // arc up at mid\n        sunDot.setAttribute('cx', x);\n        sunDot.setAttribute('cy', y);\n      }\n\n      /* ---- STORIES horizontal pin ---- */\n      var storiesOuter = document.getElementById('stories-outer');\n      var storiesStrip = document.getElementById('stories-strip');\n      var splates = document.querySelectorAll('.splate');\n      var storiesRail = document.getElementById('stories-rail').children;\n\n      function updateStories() {\n        if (mobile() || !storiesOuter) return;\n        var r = storiesOuter.getBoundingClientRect();\n        var total = storiesOuter.offsetHeight - window.innerHeight;\n        var p = Math.min(1, Math.max(0, (-r.top) / total));\n        storiesStrip.style.transform = 'translateX(' + (-p * 300) + 'vw)';\n        var centerIdx = Math.round(p * 3);\n        splates.forEach(function (pl, i) { pl.classList.toggle('center', i === centerIdx); });\n        for (var i = 0; i < storiesRail.length; i++) { storiesRail[i].classList.toggle('on', i <= centerIdx); }\n      }\n\n      /* ---- STARTER sticky stack scale ---- */\n      var starterOuter = document.getElementById('starter-outer');\n      var sp1 = document.getElementById('sp1'), sp2 = document.getElementById('sp2');\n      function updateStarter() {\n        if (mobile() || !starterOuter) return;\n        var r = starterOuter.getBoundingClientRect();\n        var total = starterOuter.offsetHeight - window.innerHeight;\n        var p = Math.min(1, Math.max(0, (-r.top) / total)); // 0..1 across 3 panels (2 transitions)\n        // panel1 shrinks during first half, panel2 during second half\n        var p1 = Math.min(1, p * 2);\n        var p2 = Math.max(0, Math.min(1, (p - 0.5) * 2));\n        sp1.style.transform = 'scale(' + (1 - 0.04 * p1) + ')';\n        sp2.style.transform = 'scale(' + (1 - 0.04 * p2) + ')';\n      }\n\n      /* ---- HERO scroll-linked scale/dim + frame glow warm ---- */\n      var heroVid = document.getElementById('hero-vid');\n      var heroFrame = document.getElementById('hero-frame');\n      function updateHero() {\n        var y = window.scrollY;\n        if (heroVid) {\n          heroVid.style.transform = 'scale(' + (1 + y / 2200) + ')';\n          heroVid.style.opacity = String(Math.max(0.35, 1 - y / 900));\n        }\n        // frame glow warms ember->jam over first viewport\n        var g = Math.min(1, y / window.innerHeight);\n        heroFrame.style.setProperty('--frame-glow', mix('#E2611B', '#C81E37', g));\n      }\n\n      /* ---- single rAF scroll loop ---- */\n      var ticking = false;\n      function onScroll() {\n        if (!ticking) {\n          requestAnimationFrame(function () {\n            updateHero();\n            updateSeason();\n            updateStories();\n            updateStarter();\n            ticking = false;\n          });\n          ticking = true;\n        }\n      }\n      window.addEventListener('scroll', onScroll, { passive: true });\n      window.addEventListener('resize', onScroll, { passive: true });\n      onScroll();\n\n      /* ---- STARTER flour-puff particles (vanilla) ---- */\n      var cta = document.getElementById('starter-cta');\n      if (cta) {\n        cta.addEventListener('click', function () {\n          for (var i = 0; i < 22; i++) {\n            (function () {\n              var pt = document.createElement('span');\n              pt.className = 'particle';\n              cta.appendChild(pt);\n              var dx = (Math.random() * 280 - 140);\n              var dy = -(Math.random() * 140 + 40);\n              var rot = Math.random() * 360;\n              var dur = 700 + Math.random() * 500;\n              var start = null;\n              function step(ts) {\n                if (!start) start = ts;\n                var pr = Math.min(1, (ts - start) / dur);\n                var e = 1 - Math.pow(1 - pr, 3);\n                pt.style.transform = 'translate(' + (dx * e) + 'px,' + (dy * e) + 'px) rotate(' + (rot * e) + 'deg) scale(' + (1 - 0.8 * pr) + ')';\n                pt.style.opacity = String(1 - pr);\n                if (pr < 1) requestAnimationFrame(step); else pt.remove();\n              }\n              requestAnimationFrame(step);\n            })();\n          }\n        });\n      }\n    })();\n  </script>\n",
